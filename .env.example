# Google Gemini API Key configuration
# Thay thế bằng API Key thực tế của bạn từ Google AI Studio (https://aistudio.google.com/)
EXPO_PUBLIC_GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Google Maps API Key configuration (Dành cho Android)
# Thay thế bằng API Key từ Google Cloud Console (cần kích hoạt Maps SDK for Android)
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY_HERE
